#!/usr/bin/env bash
set -euo pipefail

_tether_json_field() {
  local key="$1"
  sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -n 1
}

_tether_emit_title() {
  local value="$1"
  printf '\033]2;%s\007' "$value"
}

_tether_emit_notify() {
  local title="$1"
  local body="$2"
  printf '\033]777;notify;%s;%s\007' "$title" "$body"
}

case "${1:-}" in
  claude-running)
    _tether_emit_title "✱ Claude Code"
    ;;
  claude-waiting)
    payload="$(cat)"
    message="$(printf '%s' "$payload" | _tether_json_field message)"
    [ -n "$message" ] || message="Claude Code needs your attention"
    _tether_emit_title "· Claude Code"
    _tether_emit_notify "Claude Code" "$message"
    ;;
  codex-running)
    _tether_emit_title "✱ Codex"
    ;;
  codex-waiting)
    payload="$(cat)"
    message="$(printf '%s' "$payload" | _tether_json_field last_assistant_message)"
    [ -n "$message" ] || message="Codex needs your attention"
    _tether_emit_title "· Codex"
    _tether_emit_notify "Codex" "$message"
    ;;
  terminal-notifier)
    shift
    title=""
    body=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        -title) title="${2:-}"; shift 2 ;;
        -message) body="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    [ -n "$title" ] || title="Notification"
    _tether_emit_notify "$title" "$body"
    ;;
  *)
    exit 64
    ;;
esac
